# Supabase configuration
# Get these from Supabase dashboard > Settings > API

# Supabase project URL
SUPABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase project ref (for Edge Functions)
SUPABASE_PROJECT_ID=your-project-ref

# Supabase service role key (for Edge Functions, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
