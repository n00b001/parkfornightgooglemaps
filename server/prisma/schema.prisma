generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  googleId      String     @unique
  email         String     @unique
  name          String?
  avatar        String?
  favorites     Favorite[]
  reviews       Review[]
  visits        Visit[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Place {
  id              Int        @id
  name            String
  latitude        Float
  longitude       Float
  type            String
  description     String?
  address         String?
  rating          Float?
  reviewCount     Int        @default(0)
  photoCount      Int        @default(0)
  services        Json?      // [{code, label}]
  activities      Json?      // [{code, label}]
  photos          Json?      // [{id, url_large, url_thumb}]
  pricing         Json?      // {parking, services}
  access          Json?      // {public, height_limit, parking_places}
  contact         Json?      // {phone, email, website}
  descriptions    Json?      // {fr, en, de, es, it, nl}
  isPublic        Boolean    @default(true)
  onlineBooking   Boolean    @default(false)
  favorites       Favorite[]
  reviews         Review[]
  visits          Visit[]
  rawData         Json?
  lastFetched     DateTime   @default(now())

  @@index([latitude, longitude])
}

model Favorite {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  place     Place    @relation(fields: [placeId], references: [id])
  placeId   Int
  createdAt DateTime @default(now())

  @@unique([userId, placeId])
}

model Review {
  id        String   @id @default(uuid())
  content   String
  rating    Int
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  place     Place    @relation(fields: [placeId], references: [id])
  placeId   Int
  createdAt DateTime @default(now())
}

model Visit {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  place     Place    @relation(fields: [placeId], references: [id])
  placeId   Int
  visitedAt DateTime @default(now())

  @@unique([userId, placeId])
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire], name: "IDX_session_expire")
}
