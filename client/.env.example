# Client environment variables

# Supabase project URL (from Supabase dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (from Supabase dashboard > Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key

# URL of the backend API (Supabase Edge Function)
# Production: https://your-project-ref.supabase.co/functions/v1/api
# Development: http://localhost:54321/functions/v1/api
VITE_API_URL=http://localhost:54321/functions/v1/api

# Google Maps JavaScript API key (from Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
