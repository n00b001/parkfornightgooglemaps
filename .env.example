# Supabase PostgreSQL connection string
# Transaction-mode pooler (port 6543) — used by Prisma at runtime for queries
DATABASE_URL=postgresql://user:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session-mode pooler (port 5432) — used by Prisma for migrations
DIRECT_URL=postgresql://user:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
