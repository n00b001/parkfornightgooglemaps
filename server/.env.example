# Server environment variables

# PostgreSQL database connection string (e.g., from Render or local)
DATABASE_URL=postgresql://user:password@localhost:5432/park4night

# Session secret for signing cookies (use a strong random string in production)
SESSION_SECRET=your-session-secret-here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URL of the client app (for CORS and OAuth redirect)
CLIENT_URL=localhost:5173

# Node environment (development | production)
NODE_ENV=development

# Server port
PORT=5000
