{
  "name": "parkfornightgooglemaps",
  "version": "1.0.0",
  "description": "A modern PWA for finding and sharing parking spots with Google Maps integration",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm --prefix client install",
    "dev": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "build:client": "npm --prefix client run build",
    "start:client": "npm --prefix client preview",
    "test": "npm --prefix client test",
    "lint": "npm --prefix client run lint"
  },
  "keywords": [
    "pwa",
    "parking",
    "google-maps",
    "campsite",
    "offline-first"
  ],
  "author": "n00b001"
}
