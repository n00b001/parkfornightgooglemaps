# Server environment variables

# Supabase PostgreSQL connection string
# Transaction-mode pooler (port 6543) — used by Prisma at runtime for queries
DATABASE_URL=postgresql://user:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session-mode pooler (port 5432) — used by Prisma for migrations and by pg Pool for session storage
DIRECT_URL=postgresql://user:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Session secret for signing cookies (use a strong random string in production)
SESSION_SECRET=your-session-secret-here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URL of the client app (for CORS and OAuth redirect)
CLIENT_URL=localhost:5173

# Node environment (development | production)
NODE_ENV=development

# Server port
PORT=5000
