# Scraped place images (hundreds of MBs/GBs)
scripts/data/images/places/

# Keep vehicle icons (small, needed for the app)
!scripts/data/images/icons/
!scripts/data/images/.gitkeep

# Normalised data (generated by normalize.py)
scripts/data/normalized/

# Normaliser checkpoint (regenerated on each run)
scripts/data/normalized/normalize_checkpoint.json

# Upload script config (contains credentials)
scripts/upload/r2-config.json

# Firebase credentials
firebase-credentials.json
server/firebase-credentials.json

