generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  googleId      String     @unique
  email         String     @unique
  name          String?
  avatar        String?
  favorites     Favorite[]
  reviews       Review[]
  visits        Visit[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Place {
  id              Int           @id
  name            String
  latitude        Float
  longitude       Float
  type            PlaceType     @relation(fields: [typeId], references: [id])
  typeId          Int
  address         String?
  rating          Float?
  reviewCount     Int           @default(0)
  photoCount      Int           @default(0)
  services        PlaceService[]
  activities      PlaceActivity[]
  photos          Json?         // [{id, numero, path_thumb, path_large}]
  pricing         Json?         // {parking: "free", services: ""}
  access          Json?         // {public, height_limit, parking_places}
  contact         Json?         // {phone, email, website}
  descriptions    Json?         // {default: "English text", _original: "French source text"}
  isPublic        Boolean       @default(true)
  onlineBooking   Boolean       @default(false)
  favorites       Favorite[]
  reviews         Review[]
  visits          Visit[]
  lastFetched     DateTime      @default(now())

  @@index([latitude, longitude])
}

/// Lookup table: place type codes (English + original)
model PlaceType {
  id            Int          @id @default(autoincrement())
  englishName   String       @unique // "Parking", "Camping", etc.
  originalCode  String       @unique // "P", "PN", etc.
  places        Place[]
}

/// Lookup table: service codes (English + original)
model Service {
  id            Int          @id @default(autoincrement())
  code          String       @unique // "trash_bins", "water_point", etc.
  label         String       // "Trash bins", "Water point", etc.
  originalCode  String       @unique // "poubelle", "point_eau", etc.
  places        PlaceService[]
}

/// Lookup table: activity codes (English + original)
model Activity {
  id            Int          @id @default(autoincrement())
  code          String       @unique // "viewpoint", "swimming", etc.
  label         String       // "Viewpoint", "Swimming", etc.
  originalCode  String       @unique // "point_de_vue", "baignade", etc.
  places        PlaceActivity[]
}

/// Lookup table: vehicle type codes (English + original)
model VehicleType {
  id              Int       @id @default(autoincrement())
  code            String    @unique // "car", "motorhome", etc.
  originalCode    String    @unique // "NC", "GV", etc.
  reviews         Review[]
}

/// Junction: Place ↔ Service
model PlaceService {
  place   Place    @relation(fields: [placeId], references: [id])
  placeId Int
  service Service  @relation(fields: [serviceId], references: [id])
  serviceId Int

  @@id([placeId, serviceId])
}

/// Junction: Place ↔ Activity
model PlaceActivity {
  place    Place    @relation(fields: [placeId], references: [id])
  placeId  Int
  activity Activity @relation(fields: [activityId], references: [id])
  activityId Int

  @@id([placeId, activityId])
}

model Favorite {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  place     Place    @relation(fields: [placeId], references: [id])
  placeId   Int
  createdAt DateTime @default(now())

  @@unique([userId, placeId])
}

model Review {
  id                String       @id @default(uuid())
  content           String
  rating            Int
  vehicleType       VehicleType? @relation(fields: [vehicleTypeId], references: [id])
  vehicleTypeId     Int?
  authorName        String?
  authorId          String?      // Park4Night author ID
  user              User         @relation(fields: [userId], references: [id])
  userId            String
  place             Place        @relation(fields: [placeId], references: [id])
  placeId           Int
  createdAt         DateTime     @default(now())

  @@index([placeId])
}

model Visit {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  place     Place    @relation(fields: [placeId], references: [id])
  placeId   Int
  visitedAt DateTime @default(now())

  @@unique([userId, placeId])
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire], name: "IDX_session_expire")
}
