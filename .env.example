# Supabase PostgreSQL — transaction-mode pooler (for runtime queries)
# Connect via port 6543 with pgbouncer=true for connection pooling
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase PostgreSQL — session-mode pooler (for Prisma migrations only)
# Connect via port 5432 without pgbouncer for migration compatibility
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
